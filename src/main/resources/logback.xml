<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress tool call info messages - only show warnings and errors -->
    <root level="WARN">
        <appender-ref ref="CONSOLE" />
    </root>
    
    <!-- Optionally enable debug logging for specific components when needed -->
    <!-- <logger name="com.example.pijava.agent" level="DEBUG" /> -->
</configuration>
